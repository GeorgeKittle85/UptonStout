<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>FaceID Lab — Educational Facial Recognition</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=IBM+Plex+Mono:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/@vladmandic/face-api/dist/face-api.js"></script>
<style>
:root{
  --bg:#050c1a;--bg2:#0a1628;--bg3:#0f1e38;
  --card:#0d1829;--card2:#111f36;
  --border:rgba(0,200,255,.13);--border2:rgba(0,200,255,.25);
  --cyan:#00c8ff;--green:#00ffb3;--red:#ff3d5a;--yellow:#ffd600;--purple:#a855f7;
  --text:#ddeeff;--muted:#5b7499;--dim:#3a506b;
}
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--text);font-family:'IBM Plex Mono',monospace;min-height:100vh;overflow-x:hidden}
body::before{content:'';position:fixed;inset:0;background-image:linear-gradient(rgba(0,200,255,.025) 1px,transparent 1px),linear-gradient(90deg,rgba(0,200,255,.025) 1px,transparent 1px);background-size:48px 48px;pointer-events:none;z-index:0}
body::after{content:'';position:fixed;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--cyan),transparent);opacity:.5;z-index:10}
.wrap{max-width:1100px;margin:0 auto;padding:0 24px;position:relative;z-index:1}

/* ── HEADER ── */
header{padding:28px 0 22px;border-bottom:1px solid var(–border)}
.hdr{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px}
.logo{display:flex;align-items:center;gap:14px}
.logo-icon{width:46px;height:46px;border:2px solid var(–cyan);border-radius:12px;display:flex;align-items:center;justify-content:center;background:rgba(0,200,255,.06);flex-shrink:0}
.logo-icon svg{width:26px;height:26px}
.logo h1{font-family:‘Syne’,sans-serif;font-size:1.35rem;font-weight:800;background:linear-gradient(120deg,var(–cyan),var(–green));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.logo p{font-size:.62rem;color:var(–muted);letter-spacing:.12em;text-transform:uppercase;margin-top:1px}
.status-pill{display:flex;align-items:center;gap:8px;padding:6px 14px;background:var(–bg2);border:1px solid var(–border);border-radius:20px;font-size:.66rem}
.sdot{width:8px;height:8px;border-radius:50%;background:var(–dim);flex-shrink:0;transition:.3s}
.sdot.loading{background:var(–yellow);animation:pulse 1s infinite}
.sdot.ready{background:var(–green)}
.sdot.error{background:var(–red)}

/* ── SECTION ── */
.section{margin:28px 0}
.sec-head{display:flex;align-items:center;gap:12px;margin-bottom:18px}
.sec-num{width:26px;height:26px;border-radius:50%;background:var(–bg3);border:1px solid var(–border2);display:flex;align-items:center;justify-content:center;font-size:.68rem;color:var(–cyan);flex-shrink:0}
.sec-title{font-family:‘Syne’,sans-serif;font-size:.98rem;font-weight:700}
.sec-sub{font-size:.63rem;color:var(–muted);margin-top:1px}
.sec-line{flex:1;height:1px;background:var(–border)}

/* ── CARD ── */
.card{background:var(–card);border:1px solid var(–border);border-radius:12px;padding:20px}

/* ── BUTTONS ── */
.btn{display:inline-flex;align-items:center;gap:7px;padding:9px 20px;border-radius:8px;border:none;font-family:‘IBM Plex Mono’,monospace;font-size:.76rem;cursor:pointer;transition:.2s;font-weight:500;line-height:1}
.btn-primary{background:linear-gradient(135deg,var(–cyan),#0070ff);color:#000}
.btn-primary:hover{opacity:.85;transform:translateY(-1px)}
.btn-ghost{background:var(–bg3);color:var(–text);border:1px solid var(–border2)}
.btn-ghost:hover{border-color:var(–cyan);color:var(–cyan)}
.btn-green{background:rgba(0,255,179,.1);color:var(–green);border:1px solid rgba(0,255,179,.25)}
.btn-green:hover{background:rgba(0,255,179,.18)}
.btn-red{background:rgba(255,61,90,.1);color:var(–red);border:1px solid rgba(255,61,90,.25)}
.btn:disabled{opacity:.35;cursor:not-allowed;transform:none!important}

/* ── PROGRESS ── */
.prog-wrap{max-width:420px;margin:16px auto 0}
.prog-row{display:flex;justify-content:space-between;font-size:.64rem;color:var(–muted);margin-bottom:5px}
.prog-track{height:5px;background:var(–bg3);border-radius:3px;overflow:hidden}
.prog-fill{height:100%;background:linear-gradient(90deg,var(–cyan),var(–green));border-radius:3px;transition:width .4s}
.prog-detail{font-size:.6rem;color:var(–dim);margin-top:6px;text-align:center}

/* ── DROPZONE ── */
.drop-zone{border:2px dashed var(–border2);border-radius:10px;padding:28px 16px;text-align:center;cursor:pointer;transition:.2s;background:rgba(0,200,255,.02)}
.drop-zone:hover,.drop-zone.dragover{border-color:var(–cyan);background:rgba(0,200,255,.05)}
.dz-icon{font-size:2rem;margin-bottom:8px}
.dz-label{font-size:.78rem;color:var(–text)}
.dz-sub{font-size:.65rem;color:var(–muted);margin-top:6px}
input[type=file]{display:none}

/* ── REF GRID ── */
.ref-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:10px;margin-top:14px}
.ref-card{background:var(–bg3);border:1px solid var(–border);border-radius:10px;overflow:hidden;position:relative;aspect-ratio:1}
.ref-card canvas{width:100%;height:100%;object-fit:cover;display:block}
.ref-card .rmv{position:absolute;top:5px;right:5px;width:20px;height:20px;border-radius:50%;background:rgba(5,12,26,.8);border:1px solid var(–border2);color:var(–muted);font-size:.6rem;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:.2s;z-index:2}
.ref-card .rmv:hover{background:var(–red);color:#fff;border-color:var(–red)}
.ref-badge{position:absolute;bottom:5px;left:5px;padding:2px 7px;border-radius:4px;font-size:.58rem;z-index:2}
.rb-ok{background:rgba(0,255,179,.2);color:var(–green);border:1px solid rgba(0,255,179,.4)}
.rb-fail{background:rgba(255,61,90,.2);color:var(–red);border:1px solid rgba(255,61,90,.4)}
.proc-overlay{position:absolute;inset:0;background:rgba(5,12,26,.85);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:8px;font-size:.63rem;color:var(–cyan);z-index:3}
.empty-state{text-align:center;padding:28px;color:var(–muted);font-size:.72rem}
.es-icon{font-size:2rem;margin-bottom:8px;opacity:.35;display:block}

/* ── STATS ROW ── */
.stats-row{display:flex;gap:10px;flex-wrap:wrap;margin:14px 0}
.stat-box{flex:1;min-width:100px;background:var(–bg2);border:1px solid var(–border);border-radius:8px;padding:10px;text-align:center}
.stat-val{font-family:‘Syne’,sans-serif;font-size:1.2rem;font-weight:700;color:var(–cyan)}
.stat-lbl{font-size:.57rem;color:var(–muted);margin-top:2px;text-transform:uppercase;letter-spacing:.08em}

/* ── COMP TABS ── */
.ctabs{display:flex;gap:8px;margin-bottom:16px}
.ctab{padding:7px 16px;border-radius:7px;border:1px solid var(–border);background:transparent;color:var(–muted);font-family:‘IBM Plex Mono’,monospace;font-size:.7rem;cursor:pointer;transition:.2s}
.ctab.active{border-color:var(–cyan);color:var(–cyan);background:rgba(0,200,255,.08)}
.cpanel{display:none}.cpanel.active{display:block}
.comp-preview{max-width:420px;margin:0 auto;margin-top:14px}
.comp-preview canvas{width:100%;border-radius:10px;display:block;border:1px solid var(–border)}

/* ── VIDEO ── */
.vid-wrap{position:relative;border-radius:10px;overflow:hidden;background:#000;aspect-ratio:4/3;max-width:420px;margin:0 auto}
.vid-wrap video,.vid-wrap canvas{position:absolute;inset:0;width:100%;height:100%;object-fit:cover}
.vid-wrap video{position:relative}
.vid-overlay{position:absolute;inset:0;pointer-events:none}
.vid-placeholder{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:8px;color:var(–muted);font-size:.72rem}
.vid-controls{display:flex;gap:8px;justify-content:center;margin-top:12px;flex-wrap:wrap}

/* ── RUN ── */
.run-wrap{text-align:center;padding:24px 0;border-top:1px solid var(–border)}
.btn-run{padding:13px 48px;font-size:.9rem;border-radius:10px;background:linear-gradient(135deg,#00c8ff,#0050ff);border:none;color:#000;font-family:‘Syne’,sans-serif;font-weight:800;cursor:pointer;transition:.25s;box-shadow:0 0 28px rgba(0,200,255,.18);letter-spacing:-.3px}
.btn-run:hover:not(:disabled){transform:translateY(-2px);box-shadow:0 6px 40px rgba(0,200,255,.3)}
.btn-run:disabled{opacity:.35;cursor:not-allowed;transform:none}
.run-hint{font-size:.68rem;color:var(–muted);margin-top:10px}

/* ── SPINNER ── */
.spinner{width:22px;height:22px;border:2px solid var(–border2);border-top-color:var(–cyan);border-radius:50%;animation:spin 1s linear infinite;display:inline-block;flex-shrink:0}
.spinner.lg{width:38px;height:38px;border-width:3px;margin-bottom:14px}

/* ── RESULTS ── */
#resultsSection{display:none}
.verdict-box{border-radius:14px;padding:28px;text-align:center;margin-bottom:20px;border:2px solid}
.vb-match{background:rgba(0,255,179,.04);border-color:rgba(0,255,179,.4)}
.vb-nomatch{background:rgba(255,61,90,.04);border-color:rgba(255,61,90,.4)}
.vb-uncertain{background:rgba(255,214,0,.04);border-color:rgba(255,214,0,.4)}
.verdict-icon{font-size:2.8rem;margin-bottom:8px}
.verdict-label{font-family:‘Syne’,sans-serif;font-size:2rem;font-weight:800;letter-spacing:-1px}
.vb-match .verdict-label{color:var(–green)}
.vb-nomatch .verdict-label{color:var(–red)}
.vb-uncertain .verdict-label{color:var(–yellow)}
.verdict-sub{font-size:.72rem;color:var(–muted);margin-top:6px;line-height:1.6}

/* ── GAUGE ── */
.gauge-wrap{margin:18px 0}
.gauge-lbl{font-size:.63rem;color:var(–muted);text-transform:uppercase;letter-spacing:.1em;margin-bottom:7px}
.gauge-track{height:10px;background:var(–bg3);border-radius:5px;position:relative;overflow:visible}
.gauge-fill{height:100%;border-radius:5px;transition:width 1s cubic-bezier(.4,0,.2,1)}
.gauge-marker{position:absolute;top:-4px;width:18px;height:18px;border-radius:50%;border:3px solid var(–bg);margin-left:-9px;transition:left 1s cubic-bezier(.4,0,.2,1)}
.thresh-line{position:absolute;top:-6px;width:2px;height:22px;background:var(–yellow)}
.thresh-label{position:absolute;top:-20px;font-size:.57rem;color:var(–yellow);transform:translateX(-50%);white-space:nowrap}
.gauge-scale{display:flex;justify-content:space-between;font-size:.58rem;color:var(–dim);margin-top:5px}

/* ── TABS ── */
.tabs-bar{display:flex;gap:2px;border-bottom:1px solid var(–border);margin-bottom:18px}
.tbtn{padding:8px 14px;background:transparent;border:none;color:var(–muted);font-family:‘IBM Plex Mono’,monospace;font-size:.7rem;cursor:pointer;border-bottom:2px solid transparent;transition:.2s;margin-bottom:-1px}
.tbtn.active{color:var(–cyan);border-bottom-color:var(–cyan)}
.tpanel{display:none}.tpanel.active{display:block}

/* ── DATA CELLS ── */
.info-row{display:flex;gap:10px;flex-wrap:wrap;margin:12px 0}
.info-box{flex:1;min-width:130px;background:var(–bg3);border:1px solid var(–border);border-radius:8px;padding:9px 12px;font-size:.66rem}
.info-box label{color:var(–muted);display:block;margin-bottom:3px;font-size:.57rem;text-transform:uppercase;letter-spacing:.1em}

/* ── PER-PHOTO LIST ── */
.photo-list{display:flex;flex-direction:column;gap:8px;margin-top:12px}
.photo-row{display:flex;align-items:center;gap:12px;padding:10px 14px;background:var(–bg2);border:1px solid var(–border);border-radius:8px}
.photo-thumb{width:44px;height:44px;border-radius:6px;object-fit:cover;flex-shrink:0;border:1px solid var(–border)}
.photo-thumb canvas{width:44px;height:44px;border-radius:6px}
.photo-info{flex:1;min-width:0}
.photo-name{font-size:.68rem;color:var(–text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.photo-dist{font-size:.62rem;color:var(–muted);margin-top:2px}
.mini-bar-wrap{width:100px;height:6px;background:var(–bg3);border-radius:3px;overflow:hidden;flex-shrink:0}
.mini-bar{height:100%;border-radius:3px;transition:width .6s}

/* ── DESCRIPTOR VIZ ── */
.desc-viz{height:80px;display:flex;align-items:flex-end;gap:1px;margin:10px 0;background:var(–bg3);border:1px solid var(–border);border-radius:8px;padding:6px;overflow:hidden}
.dbar{flex:1;min-width:2px;border-radius:1px 1px 0 0;opacity:.9}
.desc-legend{display:flex;gap:16px;font-size:.6rem;color:var(–muted);margin-bottom:6px}
.desc-legend span{display:flex;align-items:center;gap:5px}
.desc-legend i{width:10px;height:10px;border-radius:2px;display:inline-block}

/* ── GEO GRID ── */
.geo-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:10px;margin-top:12px}
.geo-item{background:var(–bg2);border:1px solid var(–border);border-radius:8px;padding:10px}
.geo-name{font-size:.6rem;color:var(–muted);text-transform:uppercase;letter-spacing:.08em}
.geo-val{font-family:‘Syne’,sans-serif;font-size:1rem;font-weight:700;color:var(–green);margin-top:4px}
.geo-desc{font-size:.58rem;color:var(–dim);margin-top:2px}

/* ── LANDMARKS CANVAS PREVIEW ── */
.lm-preview-wrap{max-width:340px;margin:0 auto 16px}
.lm-preview-wrap canvas{width:100%;border-radius:10px;border:1px solid var(–border)}
.lm-groups{display:flex;flex-wrap:wrap;gap:8px;margin-top:10px}
.lm-group{background:var(–bg2);border:1px solid var(–border);border-radius:8px;padding:9px 12px;flex:1;min-width:120px}
.lm-gname{font-size:.6rem;color:var(–muted);text-transform:uppercase;letter-spacing:.08em}
.lm-gval{font-family:‘Syne’,sans-serif;font-size:1.1rem;font-weight:700;margin-top:3px}
.lm-gsub{font-size:.58rem;color:var(–dim);margin-top:1px}

/* ── GUIDE ── */
.guide-intro{font-size:.76rem;color:var(–muted);line-height:1.75;max-width:680px;margin-bottom:22px}
.accordion{display:flex;flex-direction:column;gap:10px}
.acc-item{border:1px solid var(–border);border-radius:10px;overflow:hidden}
.acc-head{display:flex;align-items:center;gap:10px;padding:13px 16px;cursor:pointer;background:var(–card);transition:.2s;user-select:none}
.acc-head:hover{background:var(–card2)}
.acc-num{width:24px;height:24px;border-radius:6px;border:1px solid var(–border2);display:flex;align-items:center;justify-content:center;font-size:.63rem;color:var(–cyan);flex-shrink:0}
.acc-title{font-family:‘Syne’,sans-serif;font-size:.86rem;font-weight:700;flex:1}
.acc-tag{font-size:.58rem;padding:2px 8px;border-radius:4px;flex-shrink:0}
.t-classical{background:rgba(255,214,0,.1);color:var(–yellow);border:1px solid rgba(255,214,0,.3)}
.t-neural{background:rgba(168,85,247,.1);color:var(–purple);border:1px solid rgba(168,85,247,.3)}
.t-math{background:rgba(0,200,255,.1);color:var(–cyan);border:1px solid rgba(0,200,255,.3)}
.acc-arrow{color:var(–muted);transition:.25s;font-size:.75rem;flex-shrink:0}
.acc-head.open .acc-arrow{transform:rotate(180deg)}
.acc-body{display:none;padding:18px 16px;background:var(–bg2);font-size:.74rem;line-height:1.8;color:var(–muted)}
.acc-body.open{display:block}
.acc-body h4{font-family:‘Syne’,sans-serif;font-size:.84rem;color:var(–text);margin:14px 0 7px}
.acc-body h4:first-child{margin-top:0}
.acc-body p{margin-bottom:9px}
.acc-body ul{margin:0 0 10px 18px}
.acc-body li{margin-bottom:3px}
.acc-body code{background:var(–bg3);padding:1px 6px;border-radius:4px;color:var(–cyan);font-size:.7rem}
.formula{background:var(–bg3);border:1px solid var(–border2);border-radius:8px;padding:11px 14px;margin:10px 0;text-align:center;font-size:.78rem;color:var(–green);letter-spacing:.03em}
.cmp-table{width:100%;border-collapse:collapse;margin:10px 0;font-size:.68rem}
.cmp-table th{text-align:left;padding:7px 10px;background:var(–bg3);color:var(–cyan);font-weight:500;border:1px solid var(–border)}
.cmp-table td{padding:6px 10px;border:1px solid var(–border)}
.cmp-table tr:nth-child(even) td{background:rgba(0,200,255,.02)}
.hbox{padding:10px 14px;border-radius:8px;margin:10px 0;font-size:.71rem;line-height:1.7}
.hb-c{background:rgba(0,200,255,.06);border:1px solid rgba(0,200,255,.2);color:var(–text)}
.hb-y{background:rgba(255,214,0,.06);border:1px solid rgba(255,214,0,.2);color:var(–text)}
.hb-g{background:rgba(0,255,179,.06);border:1px solid rgba(0,255,179,.2);color:var(–text)}

/* ── TOAST ── */
.notify{position:fixed;bottom:20px;right:20px;z-index:200;display:flex;flex-direction:column;gap:7px;pointer-events:none}
.toast{padding:9px 14px;border-radius:8px;font-size:.7rem;border:1px solid;pointer-events:auto;animation:slideIn .25s ease;max-width:290px}
.ti{background:rgba(0,200,255,.12);border-color:rgba(0,200,255,.3);color:var(–cyan)}
.ts{background:rgba(0,255,179,.12);border-color:rgba(0,255,179,.3);color:var(–green)}
.te{background:rgba(255,61,90,.12);border-color:rgba(255,61,90,.3);color:var(–red)}

@keyframes spin{to{transform:rotate(360deg)}}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.35}}
@keyframes fadeUp{from{transform:translateY(10px);opacity:0}to{transform:none;opacity:1}}
@keyframes slideIn{from{transform:translateX(14px);opacity:0}to{transform:none;opacity:1}}
.fade-up{animation:fadeUp .4s ease both}
</style>

</head>
<body>
<div class="notify" id="notify"></div>
<div class="wrap">

<!-- HEADER -->

<header>
  <div class="hdr">
    <div class="logo">
      <div class="logo-icon">
        <svg viewBox="0 0 24 24" fill="none">
          <rect x="3" y="3" width="5" height="5" rx="1" stroke="#00c8ff" stroke-width="1.5"/>
          <rect x="16" y="3" width="5" height="5" rx="1" stroke="#00c8ff" stroke-width="1.5"/>
          <rect x="3" y="16" width="5" height="5" rx="1" stroke="#00c8ff" stroke-width="1.5"/>
          <rect x="16" y="16" width="5" height="5" rx="1" stroke="#00c8ff" stroke-width="1.5"/>
          <circle cx="12" cy="12" r="3" stroke="#00ffb3" stroke-width="1.5"/>
          <path d="M12 6.5V9M12 15v2.5M6.5 12H9M15 12h2.5" stroke="#00c8ff" stroke-width="1.2" stroke-linecap="round"/>
        </svg>
      </div>
      <div>
        <h1>FaceID Lab</h1>
        <p>Educational Facial Recognition System</p>
      </div>
    </div>
    <div class="status-pill">
      <div class="sdot" id="sdot"></div>
      <span id="statusTxt">Models not loaded</span>
    </div>
  </div>
</header>

<!-- STEP 0: LOAD MODELS -->

<div class="section" id="loadSection">
  <div class="card" style="text-align:center;padding:32px 20px">
    <div style="font-size:2.2rem;margin-bottom:10px">🧠</div>
    <div style="font-family:'Syne',sans-serif;font-size:1.1rem;font-weight:700;margin-bottom:8px">Load Neural Network Models</div>
    <div style="font-size:.72rem;color:var(--muted);max-width:520px;margin:0 auto 20px;line-height:1.7">
      Downloads 3 models via <code style="background:var(--bg3);padding:1px 5px;border-radius:3px;color:var(--cyan)">cdn.jsdelivr.net</code>:
      SSD MobileNet v1 (face detection), 68-point Landmark CNN, and ResNet-34 face recognition. All run locally in your browser.
    </div>
    <div id="progWrap" style="display:none" class="prog-wrap">
      <div class="prog-row"><span id="progLabel">Loading...</span><span id="progPct">0%</span></div>
      <div class="prog-track"><div class="prog-fill" id="progFill" style="width:0%"></div></div>
      <div class="prog-detail" id="progDetail">Initializing...</div>
    </div>
    <button class="btn btn-primary" id="loadBtn" onclick="loadModels()" style="margin-top:4px">
      ⬇ Load Models &amp; Start
    </button>
  </div>
</div>

<!-- STEP 1: REFERENCE PHOTOS -->

<div class="section" id="refSection" style="display:none">
  <div class="sec-head">
    <div class="sec-num">1</div>
    <div><div class="sec-title">Reference Photos</div><div class="sec-sub">Upload 2–6 photos of the subject — more photos improve accuracy</div></div>
    <div class="sec-line"></div>
    <span id="refBadge" style="font-size:.65rem;color:var(--muted)">0 / 6</span>
  </div>
  <div class="card">
    <div class="drop-zone" id="refDrop" onclick="document.getElementById('refIn').click()">
      <div class="dz-icon">📸</div>
      <div class="dz-label">Drag &amp; drop or click to upload</div>
