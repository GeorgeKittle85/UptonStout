// ──────────────────────────────────────────────
//  ACCORDION
// ──────────────────────────────────────────────
function togAcc(head){
  const body=head.nextElementSibling, was=head.classList.contains('open');
  document.querySelectorAll('.acc-head.open').forEach(h=>{ h.classList.remove('open'); h.nextElementSibling.classList.remove('open'); });
  if(!was){ head.classList.add('open'); body.classList.add('open'); }
}
window.addEventListener('load',()=>{ const h=document.querySelector('.acc-head'); if(h){h.classList.add('open');h.nextElementSibling.classList.add('open');} });

// ──────────────────────────────────────────────
//  DRAG + DROP HELPER
// ──────────────────────────────────────────────
function dnd(id, cb){
  const el=$(id);
  el.addEventListener('dragover', e=>{ e.preventDefault(); el.classList.add('dragover'); });
  el.addEventListener('dragleave', ()=>el.classList.remove('dragover'));
  el.addEventListener('drop', e=>{ e.preventDefault(); el.classList.remove('dragover'); cb(e.dataTransfer.files); });
}
