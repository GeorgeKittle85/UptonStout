function switchRTab(name,btn){
  document.querySelectorAll('.tabs-bar .tbtn').forEach(b=>b.classList.remove('active'));
  document.querySelectorAll('.tpanel').forEach(p=>p.classList.remove('active'));
  btn.classList.add('active'); $('tab-'+name).classList.add('active');
