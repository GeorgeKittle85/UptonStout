<script>
// ──────────────────────────────────────────────
//  GLOBALS
// ──────────────────────────────────────────────
const MODEL_URL = 'https://cdn.jsdelivr.net/npm/@vladmandic/face-api/model';
const $ = id => document.getElementById(id);
let modelsReady = false;
let refItems = []; // {id, img, canvas, descriptor, landmarks, detection, name}
let compData = null; // {canvas, descriptor, landmarks, detection}
let camStream = null, liveOn = false, liveTimer = null;

// ──────────────────────────────────────────────
//  UTILITIES
// ──────────────────────────────────────────────
function toast(msg, type='i', dur=4000){
  const el = document.createElement('div');
  el.className = 'toast t'+type;
  el.textContent = msg;
  $('notify').appendChild(el);
  setTimeout(() => el.remove(), dur);
}
function setStatus(state, txt){ $('sdot').className='sdot '+state; $('statusTxt').textContent=txt; }
function vecNorm(v){ return Math.sqrt(Array.from(v).reduce((s,x)=>s+x*x,0)); }
function cosSim(a,b){
  let d=0,na=0,nb=0;
  for(let i=0;i<a.length;i++){d+=a[i]*b[i];na+=a[i]*a[i];nb+=b[i]*b[i];}
  return d/(Math.sqrt(na*nb)||1);
}
function dot(a,b){ return Array.from(a).reduce((s,x,i)=>s+x*b[i],0); }
function avgDescs(descs){
  const n=descs.length, out=new Float32Array(128);
  for(const d of descs) for(let i=0;i<128;i++) out[i]+=d[i]/n;
  return out;
}
function updateRunBtn(){
  const ok = refItems.filter(r=>r.descriptor).length>=1 && compData?.descriptor;
  $('runBtn').disabled = !ok;
  if(!ok) $('runHint').textContent = !refItems.length && !compData ? 'Add reference photos and a comparison image to begin'
    : !refItems.filter(r=>r.descriptor).length ? 'Need at least 1 reference photo with a detected face'
    : 'Add a comparison photo or capture a snapshot';
  else $('runHint').textContent = `Ready — ${refItems.filter(r=>r.descriptor).length} reference descriptor${refItems.filter(r=>r.descriptor).length>1?'s':''} averaged`;
}

// ──────────────────────────────────────────────
//  MODEL LOADING
// ──────────────────────────────────────────────
async function loadModels(){
  $('loadBtn').disabled = true;
  $('progWrap').style.display = 'block';
  setStatus('loading','Loading models…');

  const steps = [
    { label:'SSD MobileNet v1 (detection)',   fn: ()=>faceapi.nets.ssdMobilenetv1.loadFromUri(MODEL_URL) },
    { label:'68-point Landmark CNN',           fn: ()=>faceapi.nets.faceLandmark68Net.loadFromUri(MODEL_URL) },
    { label:'ResNet-34 Recognition network',  fn: ()=>faceapi.nets.faceRecognitionNet.loadFromUri(MODEL_URL) },
  ];

  for(let i=0;i<steps.length;i++){
    const s=steps[i];
    $('progLabel').textContent = `Loading: ${s.label}`;
    $('progDetail').textContent = `${i+1} / ${steps.length}`;
    $('progPct').textContent = Math.round((i/steps.length)*100)+'%';
    $('progFill').style.width = Math.round((i/steps.length)*100)+'%';
    try{ await s.fn(); }
    catch(e){
      setStatus('error','Failed to load: '+s.label);
      toast('Load error: '+e.message,'e',8000);
      $('loadBtn').disabled=false;
      console.error(e); return;
    }
    $('progPct').textContent = Math.round(((i+1)/steps.length)*100)+'%';
    $('progFill').style.width = Math.round(((i+1)/steps.length)*100)+'%';
  }

  modelsReady = true;
  setStatus('ready','All models ready');
  $('loadSection').style.display = 'none';
  $('refSection').style.display = 'block';
  $('compSection').style.display = 'block';
  $('runWrap').style.display = 'block';
  toast('All 3 models loaded — running in browser!','s');
}

// ──────────────────────────────────────────────
//  REFERENCE PHOTOS
// ──────────────────────────────────────────────
dnd('refDrop', files => handleRefFiles(files));
async function handleRefFiles(files){
  if(!modelsReady){ toast('Load models first','e'); return; }
  const arr = Array.from(files).slice(0, 6-refItems.length);
  for(const f of arr){
    if(!f.type.startsWith('image/')){ toast('Image files only','e'); continue; }
    if(refItems.length>=6){ toast('Max 6 reference photos','e'); break; }
    await addRefPhoto(f);
  }
  updateRefUI(); updateRunBtn();
}

async function addRefPhoto(file){
  const id = Date.now()+Math.random();
  const item = { id, name:file.name, descriptor:null, landmarks:null, detection:null, canvas:null };
  refItems.push(item);
  $('refEmpty').style.display='none';

  // Create card with spinner
  const card = document.createElement('div');
  card.className='ref-card'; card.id='rc-'+id;
  const ov = document.createElement('div');
  ov.className='proc-overlay'; ov.id='ov-'+id;
  ov.innerHTML='<div class="spinner"></div><span>Detecting…</span>';
  card.appendChild(ov);
  const rmv = document.createElement('div');
  rmv.className='rmv'; rmv.textContent='✕'; rmv.onclick=()=>removeRef(id);
  card.appendChild(rmv);
  $('refGrid').appendChild(card);

  // Load image
  const img = new Image();
  img.src = URL.createObjectURL(file);
  await new Promise(r=>img.onload=r);
  item.img = img;

  // Draw to canvas
  const cv = document.createElement('canvas');
  cv.width=img.width; cv.height=img.height;
  cv.getContext('2d').drawImage(img,0,0);

  // Detect
  try{
    const result = await faceapi.detectSingleFace(img, new faceapi.SsdMobilenetv1Options({ minConfidence:0.5 }))
      .withFaceLandmarks().withFaceDescriptor();

    if(result){
      item.descriptor = result.descriptor;
      item.landmarks  = result.landmarks;
      item.detection  = result.detection;

      // Draw overlays
      const ds = { width:img.width, height:img.height };
      faceapi.matchDimensions(cv, ds);
      const res = faceapi.resizeResults(result, ds);
      new faceapi.draw.DrawBox(res.detection.box,{ boxColor:'#00ffb3', lineWidth:2, label:'' }).draw(cv);
      new faceapi.draw.DrawFaceLandmarks(res.landmarks,{ drawLines:true, lineColor:'rgba(0,200,255,.6)', lineWidth:1, pointColor:'rgba(0,255,179,.9)', pointSize:2 }).draw(cv);

      const badge = document.createElement('div');
      badge.className='ref-badge rb-ok'; badge.textContent='✓ Face';
      card.appendChild(badge);
    } else {
      cv.getContext('2d').fillStyle='rgba(255,61,90,.25)'; cv.getContext('2d').fillRect(0,0,cv.width,cv.height);
      const badge = document.createElement('div');
      badge.className='ref-badge rb-fail'; badge.textContent='✗ No face';
      card.appendChild(badge);
      toast('No face found in '+file.name,'e');
    }
  }catch(e){ console.error(e); toast('Error: '+e.message,'e'); }

  item.canvas = cv;
  card.insertBefore(cv, ov);
  ov.remove();
}

function removeRef(id){
  refItems = refItems.filter(r=>r.id!=id);
  document.querySelector('#rc-'+id)?.remove();
  if(!refItems.length) $('refEmpty').style.display='block';
  updateRefUI(); updateRunBtn();
}

function updateRefUI(){
  const n=refItems.length, wf=refItems.filter(r=>r.descriptor).length;
  $('refBadge').textContent=n+' / 6';
  if(n>0){
    $('refStats').style.display='flex';
    $('stCount').textContent=n; $('stFaces').textContent=wf;
    const confs=refItems.filter(r=>r.detection).map(r=>r.detection.score);
    $('stConf').textContent=confs.length ? (confs.reduce((a,b)=>a+b,0)/confs.length*100).toFixed(0)+'%' : '—';
  } else $('refStats').style.display='none';
}

// ──────────────────────────────────────────────
//  COMPARISON — UPLOAD
// ──────────────────────────────────────────────
dnd('compDrop', files => handleCompFile(files[0]));
async function handleCompFile(file){
  if(!modelsReady){ toast('Load models first','e'); return; }
  if(!file||!file.type.startsWith('image/')){ toast('Image files only','e'); return; }

  const img = new Image();
  img.src = URL.createObjectURL(file);
  await new Promise(r=>img.onload=r);

  const cv = $('compCanvas');
  cv.width=img.width; cv.height=img.height;
  cv.getContext('2d').drawImage(img,0,0);
  $('compPreview').style.display='block';
  $('compOkLabel').textContent='';
  toast('Processing comparison image…','i',2000);

  await runCompDetect(img, cv, $('compOkLabel'));
  updateRunBtn();
}

// ──────────────────────────────────────────────
//  CAMERA
// ──────────────────────────────────────────────
function switchCTab(name, btn){
  document.querySelectorAll('.ctab').forEach(b=>b.classList.remove('active'));
  document.querySelectorAll('.cpanel').forEach(p=>p.classList.remove('active'));
  btn.classList.add('active'); $('cpanel-'+name).classList.add('active');
}

async function startCam(){
  try{
    camStream = await navigator.mediaDevices.getUserMedia({video:{width:640,height:480,facingMode:'user'}});
    const v=$('vidEl'); v.srcObject=camStream; await new Promise(r=>v.onloadedmetadata=r); v.play();
    $('vidPH').style.display='none';
    $('camStartBtn').style.display='none';
    ['camStopBtn','snapBtn','liveBtn'].forEach(id=>$(id).style.display='inline-flex');
    toast('Camera started','s');
  }catch(e){ toast('Camera: '+e.message,'e'); }
}

function stopCam(){
  if(camStream){ camStream.getTracks().forEach(t=>t.stop()); camStream=null; }
  if(liveTimer){ clearInterval(liveTimer); liveTimer=null; liveOn=false; }
  const v=$('vidEl'); v.srcObject=null;
  $('vidPH').style.display='flex';
  $('camStartBtn').style.display='inline-flex';
  ['camStopBtn','snapBtn','liveBtn'].forEach(id=>$(id).style.display='none');
  $('liveBtn').textContent='⚡ Live: OFF';
  const ov=$('vidOverlay'); ov.getContext('2d').clearRect(0,0,ov.width,ov.height);
}

async function takeSnap(){
  const v=$('vidEl'), sc=$('snapCanvas');
  sc.width=v.videoWidth; sc.height=v.videoHeight;
  sc.getContext('2d').drawImage(v,0,0);
  $('snapPreview').style.display='block'; $('snapOkLabel').textContent='';
  toast('Processing snapshot…','i',2000);
  await runCompDetect(sc, sc, $('snapOkLabel'));
  updateRunBtn();
}

function toggleLive(){
  if(!camStream){ toast('Start camera first','e'); return; }
  liveOn=!liveOn;
  $('liveBtn').textContent='⚡ Live: '+(liveOn?'ON':'OFF');
  if(liveOn){ toast('Live analysis ON — every 1.5 s','i'); liveTimer=setInterval(liveFrame,1500); }
  else{ clearInterval(liveTimer); liveTimer=null; }
}

async function liveFrame(){
  if(!camStream||!modelsReady) return;
  const v=$('vidEl'), ov=$('vidOverlay');
  ov.width=v.videoWidth; ov.height=v.videoHeight;
  const ctx=ov.getContext('2d'); ctx.clearRect(0,0,ov.width,ov.height);

  try{
    const result = await faceapi.detectSingleFace(v, new faceapi.SsdMobilenetv1Options({minConfidence:.5}))
      .withFaceLandmarks().withFaceDescriptor();
    if(!result) return;

    const ds={width:v.videoWidth,height:v.videoHeight};
    faceapi.matchDimensions(ov,ds);
    const res=faceapi.resizeResults(result,ds);

    let label='Detected', color='#ffd600';
    const refs=refItems.filter(r=>r.descriptor);
    if(refs.length){
      const avg=avgDescs(refs.map(r=>r.descriptor));
      const dist=faceapi.euclideanDistance(avg, result.descriptor);
      const match=dist<0.6;
      label=match?`MATCH  d=${dist.toFixed(3)}`:`NO MATCH  d=${dist.toFixed(3)}`;
      color=match?'#00ffb3':'#ff3d5a';
      compData={descriptor:result.descriptor,landmarks:result.landmarks,detection:result.detection,canvas:ov};
      updateRunBtn();
    }
    new faceapi.draw.DrawBox(res.detection.box,{boxColor:color,lineWidth:2,label}).draw(ov);
    new faceapi.draw.DrawFaceLandmarks(res.landmarks,{drawLines:true,lineColor:'rgba(0,200,255,.5)',lineWidth:1,pointColor:color,pointSize:2}).draw(ov);
  }catch(e){ console.error(e); }
}

// ──────────────────────────────────────────────
//  SHARED COMP DETECT
// ──────────────────────────────────────────────
async function runCompDetect(src, cv, okLabel){
  try{
    const result = await faceapi.detectSingleFace(src, new faceapi.SsdMobilenetv1Options({minConfidence:.4}))
      .withFaceLandmarks().withFaceDescriptor();
    if(result){
      compData={descriptor:result.descriptor,landmarks:result.landmarks,detection:result.detection,canvas:cv};
      const ds={width:cv.width,height:cv.height};
      faceapi.matchDimensions(cv,ds);
      const res=faceapi.resizeResults(result,ds);
      new faceapi.draw.DrawBox(res.detection.box,{boxColor:'#00c8ff',lineWidth:2,label:''}).draw(cv);
      new faceapi.draw.DrawFaceLandmarks(res.landmarks,{drawLines:true,lineColor:'rgba(0,200,255,.5)',lineWidth:1,pointColor:'#00c8ff',pointSize:2}).draw(cv);
      okLabel.textContent='✓ Face detected — confidence '+Math.round(result.detection.score*100)+'%';
      okLabel.style.color='var(--green)';
      toast('Face detected in comparison image','s');
    } else {
      compData=null;
      okLabel.textContent='✗ No face detected — try a clearer photo';
      okLabel.style.color='var(--red)';
      toast('No face found in comparison image','e');
    }
  }catch(e){ console.error(e); toast('Detection error: '+e.message,'e'); }
}

// ──────────────────────────────────────────────
//  RUN ANALYSIS
// ──────────────────────────────────────────────
async function runAnalysis(){
  const refs=refItems.filter(r=>r.descriptor);
  if(!refs.length||!compData?.descriptor){ toast('Need reference(s) + comparison face','e'); return; }

  $('runBtn').disabled=true;
  $('runHint').textContent='Running analysis…';
  $('resultsSection').style.display='block';
  $('resultsSection').scrollIntoView({behavior:'smooth',block:'start'});
  await new Promise(r=>setTimeout(r,100));

  const avg=avgDescs(refs.map(r=>r.descriptor));
  const comp=compData.descriptor;
  const dist=faceapi.euclideanDistance(avg,comp);
  const isMatch=dist<0.6;
  const perDists=refs.map(r=>({name:r.name,dist:faceapi.euclideanDistance(r.descriptor,comp),canvas:r.canvas}));

  displayResults(dist,isMatch,avg,comp,perDists,refs);
  $('runBtn').disabled=false;
  $('runHint').textContent=isMatch?'✓ Analysis complete — MATCH found':'Analysis complete';
  toast('Analysis complete!','s');
}

// ──────────────────────────────────────────────
//  DISPLAY RESULTS
// ──────────────────────────────────────────────
function displayResults(dist,isMatch,avg,comp,perDists,refs){
  // Verdict
  const confidence=Math.max(0,Math.min(100,(1-dist/1.4)*100));
  const vb=$('verdictBox');
  vb.className='verdict-box '+(dist<0.5?'vb-match':dist<0.6?'vb-uncertain':'vb-nomatch')+' fade-up';
  $('vIcon').textContent=dist<0.5?'✅':dist<0.6?'🤔':'❌';
  $('vLabel').textContent=dist<0.5?'MATCH':dist<0.6?'UNCERTAIN':'NO MATCH';
  $('vSub').textContent=`Euclidean distance: ${dist.toFixed(4)} — threshold: 0.6 — ${isMatch?'same person identified':'different person'}`;

  // Gauge (map 0→1.4 to 0→100%)
  const pct=Math.min(100,(dist/1.4)*100);
  const col=dist<0.4?'var(--green)':dist<0.6?'var(--yellow)':'var(--red)';
  $('gFill').style.cssText=`width:${pct}%;background:linear-gradient(90deg,var(--green),var(--yellow) 43%,var(--red))`;
  $('gMark').style.cssText=`left:${pct}%;background:${col};border:3px solid var(--bg)`;

  // Overview
  $('ovStats').innerHTML=`
    <div class="stat-box"><div class="stat-val" style="color:${col}">${dist.toFixed(4)}</div><div class="stat-lbl">Distance</div></div>
    <div class="stat-box"><div class="stat-val" style="color:${col}">${confidence.toFixed(1)}%</div><div class="stat-lbl">Similarity</div></div>
    <div class="stat-box"><div class="stat-val">0.600</div><div class="stat-lbl">Threshold</div></div>
    <div class="stat-box"><div class="stat-val">${refs.length}</div><div class="stat-lbl">References</div></div>`;
  $('ovInfo').innerHTML=`
    <div class="info-box"><label>Verdict</label><span style="color:${col};font-weight:700">${dist<0.5?'MATCH':dist<0.6?'UNCERTAIN':'NO MATCH'}</span></div>
    <div class="info-box"><label>Distance from threshold</label><span>${(dist-0.6).toFixed(4)} (${dist<0.6?'below ✓':'above ✗'})</span></div>
    <div class="info-box"><label>Descriptor dims</label><span>128-d Float32</span></div>
    <div class="info-box"><label>Metric</label><span>Euclidean (L2)</span></div>`;

  // Per-photo
  const pl=$('photoList'); pl.innerHTML='';
  perDists.forEach(pd=>{
    const bw=Math.min(100,(pd.dist/1.4)*100);
    const c=pd.dist<0.4?'var(--green)':pd.dist<0.6?'var(--yellow)':'var(--red)';
    const row=document.createElement('div'); row.className='photo-row';
    row.innerHTML=`
      <div class="photo-thumb"><canvas id="pth-${Math.random().toString(36).slice(2)}"></canvas></div>
      <div class="photo-info">
        <div class="photo-name">${pd.name}</div>
        <div class="photo-dist" style="color:${c}">d = ${pd.dist.toFixed(4)} — ${pd.dist<0.6?'MATCH':'NO MATCH'}</div>
      </div>
      <div class="mini-bar-wrap"><div class="mini-bar" style="width:${bw}%;background:${c}"></div></div>`;
    pl.appendChild(row);
    if(pd.canvas){
      const tc=row.querySelector('canvas');
      tc.width=pd.canvas.width; tc.height=pd.canvas.height;
      tc.getContext('2d').drawImage(pd.canvas,0,0);
    }
  });

  // Descriptor bars
  const dv=$('descViz'); dv.innerHTML='';
  for(let i=0;i<128;i++){
    const av=avg[i], cv2=comp[i], diff=Math.abs(av-cv2);
    const maxH=30, aH=Math.min(maxH,Math.abs(av)*maxH*4), cH=Math.min(maxH,Math.abs(cv2)*maxH*4);
    const bc=diff<0.05?'var(--green)':diff<0.15?'var(--yellow)':'var(--red)';
    const bar=document.createElement('div'); bar.className='dbar';
    bar.style.cssText=`height:${Math.max(2,aH+cH+2)}px;background:linear-gradient(180deg,rgba(0,200,255,.8) ${aH}px,${bc} ${aH+2}px)`;
    bar.title=`dim${i+1}: ref=${av.toFixed(3)} comp=${cv2.toFixed(3)} Δ=${diff.toFixed(3)}`;
    dv.appendChild(bar);
  }
  $('normRef').textContent=vecNorm(avg).toFixed(4);
  $('normComp').textContent=vecNorm(comp).toFixed(4);
  $('cosineVal').textContent=cosSim(Array.from(avg),Array.from(comp)).toFixed(4);
  $('dotVal').textContent=dot(avg,comp).toFixed(4);

  // Landmarks
  const lm=compData.landmarks;
  if(lm){
    const lmCv=$('lmCanvas');
    const src=compData.canvas;
    if(src.width&&src.height){
      lmCv.width=src.width; lmCv.height=src.height;
      const ctx=lmCv.getContext('2d'); ctx.drawImage(src,0,0);
      const ds={width:src.width,height:src.height};
      faceapi.matchDimensions(lmCv,ds);
      const rres=faceapi.resizeResults({landmarks:lm,detection:compData.detection},ds);
      new faceapi.draw.DrawFaceLandmarks(rres.landmarks,{drawLines:true,lineColor:'rgba(0,200,255,.7)',lineWidth:1.5,pointColor:'#00ffb3',pointSize:3}).draw(lmCv);
    }
    const groups=[
      {name:'Jaw outline',pts:lm.getJawOutline(),col:'var(--cyan)'},
      {name:'Left eyebrow',pts:lm.getLeftEyeBrow(),col:'var(--purple)'},
      {name:'Right eyebrow',pts:lm.getRightEyeBrow(),col:'var(--purple)'},
      {name:'Nose bridge',pts:lm.getNoseBridge(),col:'var(--yellow)'},
      {name:'Nose base',pts:lm.getNose(),col:'var(--yellow)'},
      {name:'Left eye',pts:lm.getLeftEye(),col:'var(--green)'},
      {name:'Right eye',pts:lm.getRightEye(),col:'var(--green)'},
      {name:'Mouth',pts:lm.getMouth(),col:'var(--red)'},
    ];
    const lg=$('lmGroups'); lg.innerHTML='';
    groups.forEach(g=>{
      const el=document.createElement('div'); el.className='lm-group';
      el.innerHTML=`<div class="lm-gname">${g.name}</div><div class="lm-gval" style="color:${g.col}">${g.pts.length}</div><div class="lm-gsub">landmark pts</div>`;
      lg.appendChild(el);
    });

    // Geometry
    computeGeometry(lm);
  }
}

// ──────────────────────────────────────────────
//  GEOMETRY (classical)
// ──────────────────────────────────────────────
function computeGeometry(lm){
  const jaw=lm.getJawOutline();
  const le=lm.getLeftEye(), re=lm.getRightEye();
  const nb=lm.getNoseBridge(), nose=lm.getNose();
  const mouth=lm.getMouth();
  const ctr=pts=>({x:pts.reduce((s,p)=>s+p.x,0)/pts.length,y:pts.reduce((s,p)=>s+p.y,0)/pts.length});
  const d=(a,b)=>Math.sqrt((a.x-b.x)**2+(a.y-b.y)**2);

  const lec=ctr(le),rec=ctr(re),ipd=d(lec,rec);
  const jawW=d(jaw[0],jaw[16]);
  const jawH=d(jaw[8],ctr([...le,...re]));
  const faceAR=jawW>0?(jawW/jawH).toFixed(3):'—';
  const noseLen=d(nb[0],nb[nb.length-1]);
  const mouthW=d(mouth[0],mouth[6]);
  const mouthIPD=ipd>0?(mouthW/ipd).toFixed(3):'—';
  const eyeAsym=Math.abs(d(le[0],le[3])-d(re[0],re[3])).toFixed(2);
  const ipdFace=jawW>0?(ipd/jawW).toFixed(3):'—';
  const noseMouth=d(nb[nb.length-1],ctr(mouth)).toFixed(1);

  const metrics=[
    {name:'Face Aspect Ratio',val:faceAR,desc:'Jaw width / jaw height'},
    {name:'Interpupillary Dist',val:ipd.toFixed(1)+'px',desc:'Eye center to eye center'},
    {name:'Nose Length',val:noseLen.toFixed(1)+'px',desc:'Bridge top → tip'},
    {name:'Mouth Width',val:mouthW.toFixed(1)+'px',desc:'Corner to corner'},
    {name:'Mouth / IPD Ratio',val:mouthIPD,desc:'Normalized mouth width'},
    {name:'Eye Asymmetry',val:eyeAsym+'px',desc:'Left vs right eye width diff'},
    {name:'Ocular-Face Ratio',val:ipdFace,desc:'IPD / jaw width'},
    {name:'Nose-Mouth Gap',val:noseMouth+'px',desc:'Tip to mouth centroid'},
  ];
  const gg=$('geoGrid'); gg.innerHTML='';
  metrics.forEach(m=>{
    const el=document.createElement('div'); el.className='geo-item';
    el.innerHTML=`<div class="geo-name">${m.name}</div><div class="geo-val">${m.val}</div><div class="geo-desc">${m.desc}</div>`;
    gg.appendChild(el);
  });
}

